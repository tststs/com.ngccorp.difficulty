# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java & Kotlin
[*.{java,kt,kts}]
indent_size = 2

# JSON & YAML
[*.{json,yml,yaml}]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Gradle wrapper scripts
[gradlew]
end_of_line = lf
